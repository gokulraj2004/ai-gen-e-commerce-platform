# ═══════════════════════════════════════════════════════════════
# E-Commerce Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=E-Commerce Platform
APP_ENV=development
DEBUG=true
# A random secret key used for general application security.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Backend Server ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=e_commerce_platform
DB_USER=postgres
DB_PASSWORD=postgres
# Async database URL used by SQLAlchemy (asyncpg driver).
# For Docker: host should be the service name "db".
# For local dev: host should be "localhost".
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Authentication (JWT) ─────────────────────────────────────
# Secret key for signing JWT tokens. Must be different from SECRET_KEY.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
# Access token lifetime in minutes (default: 30 minutes).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days (default: 7 days).
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Frontend ─────────────────────────────────────────────────
# Base URL for API calls from the frontend.
# In Docker: use the backend service URL.
# In local dev: use localhost.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173