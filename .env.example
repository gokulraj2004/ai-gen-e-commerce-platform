# ═══════════════════════════════════════════════════════════════
# E-Commerce Platform — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=E-Commerce Platform
APP_ENV=development
DEBUG=true
# A random secret key used for general application security.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Backend Server ───────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database (PostgreSQL 15) ─────────────────────────────────
# When running with Docker Compose, DB_HOST should be "db" (the service name).
# When running locally without Docker, use "localhost".
DB_HOST=db
DB_PORT=5432
DB_NAME=e_commerce_platform
DB_USER=postgres
DB_PASSWORD=postgres
# Async connection string for SQLAlchemy (asyncpg driver).
# This is constructed from the variables above in app/config.py,
# but you can override it directly here if needed.
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Authentication (JWT) ─────────────────────────────────────
# Secret key used to sign JWT tokens. Must be different from SECRET_KEY.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
# Access token lifetime in minutes (default: 30 minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# Refresh token lifetime in days (default: 7 days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# JWT signing algorithm
JWT_ALGORITHM=HS256

# ── Frontend ─────────────────────────────────────────────────
# Base URL for API calls from the frontend.
# In production, this should point to your backend's public URL.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Include both the Docker frontend (port 3000) and Vite dev server (port 5173).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173