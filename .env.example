# ── Application ──
APP_NAME=E-Commerce Platform
APP_ENV=development
DEBUG=true
# IMPORTANT: Change this to a random secret before running. App will refuse to start with default values.
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database ──
DB_HOST=db
DB_PORT=5432
DB_NAME=e_commerce_platform
DB_USER=postgres
# IMPORTANT: Change this to a strong password before running.
DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16@db:5432/e_commerce_platform

# ── Authentication ──
# IMPORTANT: Change this to a random secret before running.
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Frontend ──
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:5173